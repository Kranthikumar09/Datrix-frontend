# Datrix Consulting — frontend environment variables
#
# Copy this file to `.env.local` (gitignored) and set the operational hosts
# used by your deployment. Do not invent production URLs.
#
# Required for API calls, media, and canonical / Open Graph URLs.

REACT_APP_API_BASE_URL=https://api.example.com/backend/api
REACT_APP_ASSET_BASE_URL=https://assets.example.com
REACT_APP_PUBLIC_SITE_URL=https://www.example.com
